<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="12dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="@dimen/card_elevation_float"
            app:cardBackgroundColor="@color/app_surface"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btnVomitBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chevron_right"
                        android:rotation="180"
                        android:padding="8dp"
                        android:contentDescription="뒤로가기"
                        app:tint="@color/app_on_surface_variant" />

                    <TextView
                        android:id="@+id/textVomitTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="토 사진 분석"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="@color/app_on_surface"
                        android:letterSpacing="-0.02"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="사진을 선택하면 AI가 색상·거품·이물질을 자동으로 분석해요"
                    android:textSize="13sp"
                    android:textColor="@color/app_on_surface_variant"
                    android:layout_marginTop="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="@dimen/card_radius_medium"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/app_surface_elevated"
                    app:strokeColor="@color/app_outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            xmlns:android="http://schemas.android.com/apk/res/android">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCaptureVomitImage"
                                style="@style/Widget.Howscat.Button.Tonal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:text="카메라 촬영" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickVomitImage"
                                style="@style/Widget.Howscat.Button.Tonal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:text="갤러리 선택" />

                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/app_outline"
                            app:strokeWidth="1dp"
                            app:cardBackgroundColor="@color/app_surface_muted">

                            <ImageView
                                android:id="@+id/imageVomitPreview"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:scaleType="centerCrop"
                                android:contentDescription="@null" />

                            <LinearLayout
                                android:id="@+id/layoutImagePlaceholder"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:orientation="vertical"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_cat"
                                    android:contentDescription="@null"
                                    app:tint="@color/app_outline_strong" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="사진을 선택하세요"
                                    android:textSize="13sp"
                                    android:textColor="@color/app_on_surface_muted" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="메모 (선택)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editVomitMemo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:gravity="top"
                        android:textColor="@color/app_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnalyzeVomit"
                    style="@style/Widget.Howscat.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="분석하고 저장하기" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/app_secondary_container"
                    app:strokeColor="@color/app_outline"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/textVomitResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:text="결과는 분석 후 표시됩니다."
                        android:textSize="14.5sp"
                        android:lineSpacingMultiplier="1.15"
                        android:textColor="@color/app_on_surface" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
