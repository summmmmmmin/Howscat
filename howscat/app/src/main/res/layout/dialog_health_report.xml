<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/app_surface"
        app:strokeWidth="0dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_hero"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="20dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#33FFFFFF">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@drawable/ic_checkup_clipboard"
                        android:contentDescription="@null"
                        app:tint="@color/white" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="주간 건강 리포트"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/textReportPeriod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="최근 7일 리포트"
                    android:textSize="12.5sp"
                    android:textColor="#CCFFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/app_primary_container"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_circle_gold"
                                android:padding="7dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_weight_scale"
                                    app:tint="@color/white"
                                    android:contentDescription="@null" />
                            </FrameLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="체중 변화"
                                android:textSize="11sp"
                                android:textColor="@color/app_on_surface_muted" />
                            <TextView
                                android:id="@+id/textReportWeightChange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="— kg"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/app_primary_dark"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        app:cardBackgroundColor="@color/app_secondary_container"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_circle_green"
                                android:padding="7dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_vomit_drop"
                                    app:tint="@color/white"
                                    android:contentDescription="@null" />
                            </FrameLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="토 횟수"
                                android:textSize="11sp"
                                android:textColor="@color/app_on_surface_muted" />
                            <TextView
                                android:id="@+id/textReportVomitCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0회"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/app_secondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2: 화장실 횟수 | 이상 횟수 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/app_surface_elevated"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/app_outline"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="화장실 기록"
                                android:textSize="11sp"
                                android:textColor="@color/app_on_surface_muted" />
                            <TextView
                                android:id="@+id/textReportLitterCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—회"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/app_on_surface"
                                android:layout_marginTop="2dp" />
                            <TextView
                                android:id="@+id/textReportLitterAbnormal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="10.5sp"
                                android:textColor="@color/semantic_warning"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        app:cardBackgroundColor="@color/app_surface_elevated"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/app_outline"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="투약 중인 약"
                                android:textSize="11sp"
                                android:textColor="@color/app_on_surface_muted" />
                            <TextView
                                android:id="@+id/textReportMedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—종"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/app_on_surface"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- 비만도 + 다음 건강일정 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/app_surface_elevated"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/app_outline"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="비만도"
                                android:textSize="11sp"
                                android:textColor="@color/app_on_surface_muted" />
                            <TextView
                                android:id="@+id/textReportObesityLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="기록없음"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/app_on_surface"
                                android:gravity="center"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        app:cardBackgroundColor="@color/app_surface_elevated"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/app_outline"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="다음 건강일정"
                                android:textSize="11sp"
                                android:textColor="@color/app_on_surface_muted" />
                            <TextView
                                android:id="@+id/textReportNextSchedule"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="일정없음"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/app_primary_dark"
                                android:gravity="center"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- 건강 인사이트 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/app_surface_elevated"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/app_outline"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="건강 인사이트"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/app_on_surface" />
                        <TextView
                            android:id="@+id/textReportInsight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="분석 중..."
                            android:textSize="13.5sp"
                            android:textColor="@color/app_on_surface_variant"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReportClose"
                    style="@style/Widget.Howscat.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="닫기" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>
