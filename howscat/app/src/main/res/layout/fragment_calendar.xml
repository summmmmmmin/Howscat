<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:background="@android:color/transparent"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="4dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMonthCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/app_surface_elevated"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="@dimen/card_elevation_soft"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMonthPrev"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="‹"
                        android:textSize="22sp"
                        android:contentDescription="이전 달" />

                    <TextView
                        android:id="@+id/textMonthYear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/app_on_surface" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMonthNext"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:contentDescription="다음 달" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutCalendarGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNextHealthSchedules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/app_surface"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="@dimen/card_elevation_soft"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="@null"
                        app:tint="@color/app_primary_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="건강 일정"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_on_surface" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="4dp"
                    android:background="@color/app_divider" />

                <LinearLayout
                    android:id="@+id/layoutNextCheckup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:id="@+id/textNextCheckup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="건강검진: 불러오는 중..."
                        android:textColor="@color/cat_text_secondary"
                        android:textSize="14.5sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckupAction"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="수정"
                        android:textSize="13sp"
                        android:textColor="@color/app_primary_dark"
                        android:textAllCaps="false"
                        android:minWidth="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="0dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutNextVaccine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="2dp">

                    <TextView
                        android:id="@+id/textNextVaccine"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="예방접종: 불러오는 중..."
                        android:textColor="@color/cat_text_secondary"
                        android:textSize="14.5sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVaccineAction"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="수정"
                        android:textSize="13sp"
                        android:textColor="@color/app_primary_dark"
                        android:textAllCaps="false"
                        android:minWidth="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="0dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/app_surface"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="@dimen/card_elevation_soft"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddCalendarMemo"
                    style="@style/Widget.Howscat.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="메모 추가" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="false"
                        app:chipSpacingHorizontal="6dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/btnFilterWeight"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="몸무게"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/btnFilterVomit"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="토 분석"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/btnFilterCheckup"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="검진"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/btnFilterVaccine"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="접종"
                            android:textSize="13sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/btnFilterMemo"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="메모"
                            android:textSize="13sp" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/textCalendarEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="선택한 날짜의 기록이 없습니다"
                    android:textStyle="bold"
                    android:textColor="@color/app_on_surface"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/listCalendarEventsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
