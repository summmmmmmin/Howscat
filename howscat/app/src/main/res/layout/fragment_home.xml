<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="24dp">

        <!-- 1. 히어로 AI 건강 카드 (골드, 큼직하게) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/app_primary"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="20dp"
                android:paddingBottom="22dp">

                <!-- 카드 헤더 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_accent_pill_white"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="AI"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_primary"
                        android:letterSpacing="0.08"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="8dp"
                        android:maxWidth="48dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="10"
                        android:text="건강 분석"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#CCFFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="♥"
                        android:textSize="20sp"
                        android:textColor="#99FFFFFF" />
                </LinearLayout>

                <!-- AI 요약 텍스트 (메인) -->
                <TextView
                    android:id="@+id/textAiSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="분석 중..."
                    android:textColor="@color/white"
                    android:textSize="15.5sp"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. 빠른 기록 섹션 헤더 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="14dp"
            android:text="빠른 기록"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/app_on_surface"
            android:letterSpacing="-0.01" />

        <!-- 빠른 기록 아이콘 버튼 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 케어 -->
            <LinearLayout
                android:id="@+id/btnQuickCare"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_icon_circle_gold"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_cat"
                        android:contentDescription="@null"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="케어"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="건강 기록"
                    android:textSize="11sp"
                    android:textColor="@color/app_on_surface_muted" />
            </LinearLayout>

            <!-- 병원 -->
            <LinearLayout
                android:id="@+id/btnQuickHospital"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_icon_circle_green"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_hospital"
                        android:contentDescription="@null"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="병원"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="근처 동물병원"
                    android:textSize="11sp"
                    android:textColor="@color/app_on_surface_muted" />
            </LinearLayout>

            <!-- 캘린더 -->
            <LinearLayout
                android:id="@+id/btnQuickCalendar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_icon_circle_amber"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="@null"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="캘린더"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="일정 관리"
                    android:textSize="11sp"
                    android:textColor="@color/app_on_surface_muted" />
            </LinearLayout>

        </LinearLayout>

        <!-- 3. 물·사료 지급량 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCareSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_premium"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_weight_scale"
                        android:contentDescription="@null"
                        app:tint="@color/app_primary_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="물·사료 지급량"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_on_surface" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textCareSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.12"
                    android:textColor="@color/app_on_surface_variant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. 집사 팁 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/app_secondary_container"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_accent_pill"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="TIP"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_on_primary_container"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="집사 팁"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_on_surface"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textHomeTip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="팁을 불러오는 중..."
                    android:textColor="@color/app_on_surface"
                    android:textSize="14.5sp"
                    android:lineSpacingMultiplier="1.15"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5. 다음 건강 일정 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="@dimen/card_elevation_soft"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_premium"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="@null"
                        app:tint="@color/app_primary_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="다음 건강 일정"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_on_surface"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"
                    android:background="@color/app_divider" />

                <TextView
                    android:id="@+id/textNextHomeCheckup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="건강검진: 불러오는 중..."
                    android:textColor="@color/cat_text_secondary"
                    android:textSize="14.5sp"
                    android:lineSpacingMultiplier="1.1"
                    android:background="@drawable/bg_chip_soft"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/textNextHomeVaccine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="예방접종: 불러오는 중..."
                    android:textColor="@color/cat_text_secondary"
                    android:textSize="14.5sp"
                    android:lineSpacingMultiplier="1.1"
                    android:background="@drawable/bg_chip_soft"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
