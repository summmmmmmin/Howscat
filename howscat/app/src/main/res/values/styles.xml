<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Howscat.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius_large</item>
        <item name="cardElevation">@dimen/card_elevation_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/app_outline</item>
        <item name="cardBackgroundColor">@color/app_surface</item>
    </style>

    <style name="Widget.Howscat.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/app_on_primary</item>
        <item name="backgroundTint">@color/app_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.Howscat.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textColor">@color/app_on_primary_container</item>
        <item name="backgroundTint">@color/app_primary_container</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Howscat.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/app_primary_dark</item>
        <item name="strokeColor">@color/app_outline_strong</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Howscat.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/app_on_surface</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Howscat.BodyMuted" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/app_on_surface_variant</item>
    </style>
</resources>
